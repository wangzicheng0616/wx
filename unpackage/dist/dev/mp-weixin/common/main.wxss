.animated{ -webkit-animation-duration: .55s; animation-duration: .55s; -webkit-animation-fill-mode: both;  animation-fill-mode: both;
}
.animated-all { transition: all .3s;
}
.animated.rotate-45 { -webkit-transform: rotate(45deg); transform: rotate(45deg);
}
.animated.rotate { -webkit-animation: rotate .75s linear infinite; animation: rotate .75s linear infinite; -webkit-transform-origin: center center; transform-origin: center center;
}
.animated.scale { transition: all 1s; -webkit-animation: scale 1s ease-out infinite; animation: scale 1s ease-out infinite; -webkit-transform-origin: center center; transform-origin: center center;
}
@-webkit-keyframes rotate {
0% { -webkit-transform: rotateZ(0deg); transform: rotateZ(0deg);
}
100% { -webkit-transform: rotateZ(360deg); transform: rotateZ(360deg);
}
}
@keyframes rotate {
0% { -webkit-transform: rotateZ(0deg); transform: rotateZ(0deg);
}
100% { -webkit-transform: rotateZ(360deg); transform: rotateZ(360deg);
}
}
@-webkit-keyframes scale {
0% { -webkit-transform: scale(0.45); transform: scale(0.45);
}
50% { -webkit-transform: scale(1.45); transform: scale(1.45);
}
100% { -webkit-transform: scale(0.45); transform: scale(0.45);
}
}
@keyframes scale {
0% { -webkit-transform: scale(0.45); transform: scale(0.45);
}
50% { -webkit-transform: scale(1.45); transform: scale(1.45);
}
100% { -webkit-transform: scale(0.45); transform: scale(0.45);
}
}
.animated.fade-in { -webkit-animation: fadein .75s linear; animation: fadein .75s linear;}
@-webkit-keyframes fadein {
from { opacity: 0;
}
to { opacity: 1;
}
}
@keyframes fadein {
from { opacity: 0;
}
to { opacity: 1;
}
}
.animated.fade-out { -webkit-animation-name: fadeout; animation-name: fadeout;
}
@-webkit-keyframes fadeout {
from { opacity: 1;
}
to { opacity: 0;
}
}
@keyframes fadeout {
from { opacity: 1;
}
to { opacity: 0;
}
}
